🇺🇸美国US = NameRegex, FilterKey = "^(?=.*((?i)美国|(\b(US|USA|United States|America|Los Angeles|New York|San Jose)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇨🇦加拿大CA = NameRegex, FilterKey = "^(?=.*((?i)加拿大|(\b(CA|CAN|Canada|Vancouver|Toronto)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇲🇽墨西哥MX = NameRegex, FilterKey = "^(?=.*((?i)墨西哥|(\b(MX|MEX|Mexico|Mexico City)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"

# > 南美洲
🇧🇷巴西BR = NameRegex, FilterKey = "^(?=.*((?i)巴西|(\b(BR|BRA|Brazil|Sao Paulo)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇦🇷阿根廷AR = NameRegex, FilterKey = "^(?=.*((?i)阿根廷|根廷|(\b(AR|ARG|Argentina|Buenos Aires)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇨🇱智利CL = NameRegex, FilterKey = "^(?=.*((?i)智利|智|(\b(CL|CHL|Chile|Santiago)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇨🇴哥伦比亚CO = NameRegex, FilterKey = "^(?=.*((?i)哥伦比亚|(\b(CO|COL|Colombia|Bogota)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇵🇪秘鲁PE = NameRegex, FilterKey = "^(?=.*((?i)秘鲁|秘|(\b(PE|PER|Peru|Lima)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"

# > 非洲
🇿🇦南非ZA = NameRegex, FilterKey = "^(?=.*((?i)南非|(\b(ZA|ZAF|South Africa|Johannesburg)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇪🇬埃及EG = NameRegex, FilterKey = "^(?=.*((?i)埃及|(\b(EG|EGY|Egypt|Cairo)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇳🇬尼日利亚NG = NameRegex, FilterKey = "^(?=.*((?i)尼日利亚|(\b(NG|NGA|Nigeria|Lagos)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇰🇪肯尼亚KE = NameRegex, FilterKey = "^(?=.*((?i)肯尼亚|肯|(\b(KE|KEN|Kenya|Nairobi)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"

# > 大洋洲
🇦🇺澳大利亚AU = NameRegex, FilterKey = "^(?=.*((?i)澳大利亚|(\b(AU|AUS|Australia|Sydney|Melbourne)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇳🇿新西兰NZ = NameRegex, FilterKey = "^(?=.*((?i)新西兰|(\b(NZ|NZL|New Zealand|Auckland)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇫🇯斐济FJ = NameRegex, FilterKey = "^(?=.*((?i)斐济|斐|(\b(FJ|FJI|Fiji|Suva)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"

# > 其他
🇨🇳中国大陆CN = NameRegex, FilterKey = "^(?=.*((?i)内地|大陆|中国大陆|(\b(CN|CHN|PRC|China|Beijing|Shanghai|Shenzhen)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🎮游戏GAME = NameRegex, FilterKey = "^(?=.*((?i)游戏|🎮|(\b(GAME)(\d+)?\b)))(?!.*((?i)回国|校园)).*$"

