国际社交 = select,自动选择,香港,台湾,新加坡,日本,美国,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/StreamingSE.png
国际媒体 = select,自动选择,香港,台湾,新加坡,日本,美国,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/Streaming.png
游戏平台 = select,DIRECT,香港,台湾,新加坡,日本,美国,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Game.png
Apple = select,DIRECT,香港,台湾,新加坡,日本,美国,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Apple.png
