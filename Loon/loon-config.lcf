[Remote Filter]
# >>>>> 自动筛选地区节点 <<<<< #
♻️自动选择AUTO = NameRegex, FilterKey = "^(?=.*(.))(?!.*((?i)内地|大陆|回国|校园|群|邀请|返利|循环|官网|客服|网站|网址|获取|订阅|流量|到期|机场|下次|版本|官址|备用|过期|已用|联系|邮箱|工单|贩卖|通知|倒卖|防止|国内|地址|频道|无法|说明|使用|提示|特别|访问|支持|教程|关注|更新|作者|加入|超时|收藏|福利|邀请|好友|失联|游戏|🎮|(\b(50|100|200|300|400|500|USE|USED|TOTAL|EXPIRE|EMAIL|Panel|Channel|Author|Traffic|GAME)(\d+)?\b|(\d{4}-\d{2}-\d{2}|\dG)))).*$"

# > 亚洲
🇭🇰香港HK = NameRegex, FilterKey = "^(?=.*((?i)香港|港|(\b(HK|HKG|Hong Kong|Hong)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇲🇴澳门MO = NameRegex, FilterKey = "^(?=.*((?i)澳门|(\b(MO|MAC|Macao|Macau)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇨🇳台湾TW = NameRegex, FilterKey = "^(?=.*((?i)台湾|台|灣|(\b(TW|TWN|Tai|Taiwan)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇯🇵日本JP = NameRegex, FilterKey = "^(?=.*((?i)日本|(\b(JP|JPN|Japan|Tokyo|Osaka)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇰🇷韩国KR = NameRegex, FilterKey = "^(?=.*((?i)韩国|韩|(\b(KR|KOR|Korea|South Korea|Seoul)(\d+)?\b)))(?!.*((?i)朝鲜|PRK|North Korea|回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇸🇬新加坡SG = NameRegex, FilterKey = "^(?=.*((?i)新加坡|狮|獅|(\b(SG|SGP|Singapore)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇲🇾马来西亚MY = NameRegex, FilterKey = "^(?=.*((?i)马来西亚|马来|(\b(MY|MYS|Malaysia|KL|Kuala Lumpur)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇮🇩印度尼西亚ID = NameRegex, FilterKey = "^(?=.*((?i)印度尼西亚|印尼|(\b(ID|IDN|Indonesia|Jakarta)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇵🇭菲律宾PH = NameRegex, FilterKey = "^(?=.*((?i)菲律宾|菲|(\b(PH|PHL|Philippines|Manila)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇻🇳越南VN = NameRegex, FilterKey = "^(?=.*((?i)越南|越|(\b(VN|VNM|Vietnam|Hanoi|Ho Chi Minh)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇹🇭泰国TH = NameRegex, FilterKey = "^(?=.*((?i)泰国|(\b(TH|THA|Thailand|Bangkok)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇮🇳印度IN = NameRegex, FilterKey = "^(?=.*((?i)印度|(\b(IN|IND|India|Mumbai|Bangalore)(\d+)?\b)))(?!.*((?i)英属印度洋领地|IO|British Indian Ocean Territory|回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
🇹🇷土耳其TR = NameRegex, FilterKey = "^(?=.*((?i)土耳其|(\b(TR|TUR|Turkey|Türkiye|Turkiye|Istanbul|Ankara)(\d+)?\b)))(?!.*((?i)回国|校园|游戏|🎮|(\b(GAME)\b))).*$"
